PORT=5001
JWT_SECRET=replace_with_a_long_secret
CLIENT_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql://username:password@host/database?sslmode=require
CLEARSPORTS_BASE_URL=https://api.clearsports.dev
CLEARSPORTS_API_KEY=
CLEARSPORTS_FOOTBALL_GAMES_PATH=/v1/football/games
CLEARSPORTS_ODDS_PATH=/v1/odds
ODDS_API_BASE_URL=https://api.odds-api.io
ODDS_API_KEY=
ODDS_API_FOOTBALL_EVENTS_PATH=/v3/events
ODDS_API_ODDS_PATH=/v3/odds
FOOTBALL_LEAGUE=epl
FOOTBALL_LEAGUES=epl,la_liga,serie_a,bundesliga,ligue_1
FOOTBALL_MAX_MATCHES=120
LIVE_ODDS_REFRESH_MS=10000
GOOGLE_CLIENT_ID=
ADMIN_GOOGLE_EMAILS=admin@sportpesa.local

# For production CORS, you can allow multiple origins by separating with commas.
# Example:
# CLIENT_ORIGIN=http://localhost:5173,https://your-app.vercel.app
