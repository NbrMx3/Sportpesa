{
  "installCommand": "cd client && npm install",
  "buildCommand": "cd client && npm run build",
  "outputDirectory": "client/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://sportpesa-api.onrender.com/api/$1"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "https://sportpesa-api.onrender.com/socket.io/$1"
    },
    {
      "source": "/favicon.ico",
      "destination": "/sportpesa_logo_blue.svg"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
