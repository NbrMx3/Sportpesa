{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://sportpesa.onrender.com/api/$1"
    },
    {
      "source": "/api",
      "destination": "https://sportpesa.onrender.com/api/health"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "https://sportpesa.onrender.com/socket.io/$1"
    },
    {
      "source": "/socket.io",
      "destination": "https://sportpesa.onrender.com/socket.io"
    },
    {
      "source": "/favicon.ico",
      "destination": "/sport.svg"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
